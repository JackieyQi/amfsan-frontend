# Backend API base URL.
#
# Local development:
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
#
# Docker deployment on the shared-services network:
# NEXT_PUBLIC_API_BASE_URL=http://amfsan-web:8080
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Use the Next.js rewrite proxy for /api requests.
# Keep this true for local development to avoid browser CORS issues.
NEXT_PUBLIC_USE_PROXY=true

# Docker compose host binding.
AMFSAN_FRONTEND_HTTP_BIND=0.0.0.0
AMFSAN_FRONTEND_HTTP_PORT=3000

# Docker json-file logging.
AMFSAN_FRONTEND_LOG_MAX_SIZE=10m
AMFSAN_FRONTEND_LOG_MAX_FILE=3
